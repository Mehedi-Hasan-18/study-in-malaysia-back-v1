{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python manage.py collectstatic --noinput",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "excludeFiles": "{venv/**,.git/**,db.sqlite3,docs/**,**/__pycache__/**,**/*.pyc,**/tests.py}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
